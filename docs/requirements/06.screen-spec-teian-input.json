          "ui": { "section": "approval_budget", "control": "number", "order": 50, "read_only": true },
          "required": false,
          "example": 4000000,
          "format": { "thousand_separator": true, "decimals": 0 }
        },
        {
          "key": "budget_note",
          "label_ja": "予算備考",
          "label_en": "Budget Note",
          "type": "string",
          "ui": { "section": "approval_budget", "control": "text", "order": 60 },
          "required": false,
          "example": "4000個×1000円"
        },
        {
          "key": "department",
          "label_ja": "部門",
          "label_en": "Department",
