          "ref": { "entity": "category_lv1", "display": "name", "value": "code" },
          "ui": { "section": "classification", "control": "select", "order": 20 },
          "required": false,
          "example": "A01: 総代会"
        },
        {
          "key": "purpose",
          "label_ja": "目的",
          "label_en": "Purpose",
          "type": "reference",
          "ref": { "entity": "purpose", "display": "name", "value": "code" },
          "ui": { "section": "classification", "control": "select", "order": 30 },
          "required": false,
          "example": "A0103: 総代会組合員記念"
        },
        {
          "key": "proper_name",
          "label_ja": "固有名",
          "label_en": "Proper Name",
          "type": "string",
          "ui": { "section": "classification", "control": "text", "order": 40 },
          "required": false,
          "example": "総代会組合員記念"
        },
        {
          "key": "rival_1",
          "label_ja": "ライバル",
          "label_en": "Rival 1",
          "type": "reference",
          "ref": { "entity": "rival", "display": "name", "value": "id" },
          "ui": { "section": "rivals", "control": "select", "order": 10 },
          "required": false
        },
        {
          "key": "rival_2",
          "label_ja": "ライバル",
          "label_en": "Rival 2",
          "type": "reference",
          "ref": { "entity": "rival", "display": "name", "value": "id" },
          "ui": { "section": "rivals", "control": "select", "order": 20 },
          "required": false
        },
        {
          "key": "rival_3",
          "label_ja": "ライバル",
          "label_en": "Rival 3",
          "type": "reference",
          "ref": { "entity": "rival", "display": "name", "value": "id" },
          "ui": { "section": "rivals", "control": "select", "order": 30 },
          "required": false
        },
        {
          "key": "rival_4",
          "label_ja": "ライバル",
          "label_en": "Rival 4",
          "type": "reference",
          "ref": { "entity": "rival", "display": "name", "value": "id" },
          "ui": { "section": "rivals", "control": "select", "order": 40 },
          "required": false
