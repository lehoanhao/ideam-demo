  },
  "tables": [
    {
      "id": "mini_summary",
      "label_ja": "サマリー",
      "label_en": "Mini Summary",
      "ui": { "section": "mini_summary_grid" },
      "columns": [
        { "key": "order_date", "label_ja": "受注日", "label_en": "Order Date", "type": "date" },
        { "key": "item_name", "label_ja": "品名", "label_en": "Item Name", "type": "string" },
        { "key": "delivery_vendor", "label_ja": "納入業者", "label_en": "Delivery Vendor", "type": "string" },
        { "key": "delivery_qty", "label_ja": "納入数", "label_en": "Delivery Qty", "type": "number" },
        { "key": "delivery_unit_price", "label_ja": "納入単価", "label_en": "Delivery Unit Price", "type": "number" }
      ],
      "notes": "This table appears above the main grid and looks like a compact summary."
    },
    {
      "id": "line_items",
      "label_ja": "明細",
      "label_en": "Line Items",
      "ui": { "section": "line_items_grid" },
      "binds_to": "proposal_line",
      "row_addition": { "supported": true, "max_rows": null },
      "row_selection": { "supported": true, "field_key": "selected" },
      "notes": "Spreadsheet-like editable table."
    }
  ],
  "rules": [
    {
      "id": "budget_total_calculation",
      "type": "calculation",
      "target": "proposal.budget_total",
      "expression": "SUM(proposal_line.budget_qty * proposal_line.budget_unit_price)",
      "trigger": ["onChange:proposal_line.budget_qty", "onChange:proposal_line.budget_unit_price"],
      "notes": "Derived from UI: 予算合計 and green budget cells."
    },
    {
      "id": "mode_behavior",
      "type": "ui_mode",
      "target": "proposal.process_type",
      "notes": "処理区分 changes behavior: create/edit/operations. Exact restrictions TBD."
    }
  ],
  "unknowns_to_confirm": [
    "Exact meaning and allowed values for R承認 and P承認.",
    "Whether 削除 is a button action, a checkbox that marks for deletion, or a toggle that enables delete mode.",
    "Whether combined headers (e.g., 見積依頼区分/依頼日) should be implemented as two separate columns or one composite column.",
    "Validation: which fields are required, numeric precision, date format, and default values.",
    "Line item constraints: maximum rows, paging/virtualization requirements."
  ]
}
