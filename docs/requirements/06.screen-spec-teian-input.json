        {
          "key": "remarks",
          "label_ja": "備考",
          "label_en": "Remarks",
          "type": "string",
          "ui": { "section": "notes_audit", "control": "textarea", "order": 10 },
          "required": false
        },
        {
          "key": "line_add_date",
          "label_ja": "行追加",
          "label_en": "Row Add Date",
          "type": "date",
          "ui": { "section": "notes_audit", "control": "date", "order": 20 },
          "required": false
        },
        {
          "key": "line_add_note",
          "label_ja": "行追加(備考)",
          "label_en": "Row Add Note",
          "type": "string",
          "ui": { "section": "notes_audit", "control": "text", "order": 30 },
          "required": false
        },
        {
          "key": "change_date",
          "label_ja": "変更",
          "label_en": "Change Date",
          "type": "date",
          "ui": { "section": "notes_audit", "control": "date", "order": 40 },
          "required": false
        },
        {
          "key": "change_note",
          "label_ja": "変更(備考)",
          "label_en": "Change Note",
          "type": "string",
          "ui": { "section": "notes_audit", "control": "text", "order": 50 },
          "required": false
        }
      ],
      "derived_fields": [
        {
          "key": "budget_total",
          "formula": "SUM(line_items[].budget_qty * line_items[].budget_unit_price)",
          "notes": "Inferred from green budget cells and 予算合計."
        }
      ]
    },
    "proposal_line": {
      "description": "提案明細 (proposal line item)",
      "primary_key": "proposal_line_id",
      "belongs_to": "proposal",
      "fields": [
        {
          "key": "row_no",
          "label_ja": "行",
          "label_en": "Row No",
          "type": "integer",
          "ui": { "section": "line_items_grid", "control": "readonly", "grid_column_order": 10 },
          "required": true
        },
        {
          "key": "selected",
          "label_ja": "選択",
          "label_en": "Select",
          "type": "boolean",
          "ui": { "section": "line_items_grid", "control": "checkbox", "grid_column_order": 20 },
          "required": false,
          "default": false
        },
        {
          "key": "budget_qty",
          "label_ja": "予算数",
          "label_en": "Budget Qty",
          "type": "number",
          "ui": { "section": "line_items_grid", "control": "number", "grid_column_order": 30, "style": "green_cell" },
          "required": false,
          "format": { "decimals": 0 }
        },
        {
          "key": "budget_unit_price",
          "label_ja": "予算単価",
          "label_en": "Budget Unit Price",
          "type": "number",
          "ui": { "section": "line_items_grid", "control": "number", "grid_column_order": 40, "style": "green_cell" },
          "required": false,
          "format": { "decimals": 0 }
        },
        {
          "key": "item_group",
          "label_ja": "品群",
          "label_en": "Item Group",
          "type": "reference",
          "ref": { "entity": "item_group", "display": "name", "value": "code" },
          "ui": { "section": "line_items_grid", "control": "select", "grid_column_order": 50 },
          "required": false,
          "notes": "Dropdown list shown in image5 (e.g., 01: 食品, 02: 菓子...)."
        },
        {
          "key": "catalog_name",
          "label_ja": "カタログ名",
          "label_en": "Catalog Name",
          "type": "string",
          "ui": { "section": "line_items_grid", "control": "text", "grid_column_order": 60 },
          "required": false
        },
        {
          "key": "item_no",
          "label_ja": "品番",
