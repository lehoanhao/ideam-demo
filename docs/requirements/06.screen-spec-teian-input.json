{
  "version": "1.0",
  "source_images": ["current-system-1.jpeg", "current-system-2.png"],
  "screen": {
    "id": "proposal_entry",
    "name_ja": "提案入力",
    "name_en": "Proposal Entry",
    "description": "Proposal master + line items entry screen. Used by Sales to register/edit a proposal, manage approval statuses, dates, classifications, rivals, notes, and detailed line items.",
    "primary_roles": ["sales"],
    "related_roles": ["procurement", "approver_ceo", "admin"],
    "layout": {
      "sections": [
        {
          "id": "header",
          "name": "Header / Top controls",
          "order": 1
        },
        {
          "id": "approval_budget",
          "name": "Approval & Budget",
          "order": 2
        },
        {
          "id": "classification",
          "name": "Department / Categories",
          "order": 3
        },
        {
          "id": "rivals",
          "name": "Rival / Competitor",
          "order": 4
        },
        {
          "id": "notes_audit",
          "name": "Notes & mini audit",
          "order": 5
        },
        {
          "id": "mini_summary_grid",
          "name": "Mini summary table",
          "order": 6
        },
        {
          "id": "line_items_grid",
          "name": "Main line items grid",
          "order": 7
        }
      ]
    }
  },
  "entities": {
    "proposal": {
      "description": "提案 (proposal) master record",
      "primary_key": "proposal_id",
      "fields": [
        {
          "key": "process_type",
          "label_ja": "処理区分",
          "label_en": "Process Type",
          "type": "enum",
          "ui": { "section": "header", "control": "select", "order": 10 },
          "required": true,
          "enum": [
            { "value": "1", "label_ja": "登録", "label_en": "Create/Register" },
            { "value": "2", "label_ja": "修正", "label_en": "Edit/Modify" },
            { "value": "3", "label_ja": "業務", "label_en": "Operations" }
          ],
          "notes": "Values inferred from screenshot."
        },
        {
          "key": "owner_user",
          "label_ja": "担当者",
          "label_en": "Owner",
          "type": "reference",
          "ref": { "entity": "user", "display": "name", "value": "id" },
          "ui": { "section": "header", "control": "select", "order": 20 },
          "required": true,
          "example": "18: 加藤誠"
        },
        {
          "key": "customer",
          "label_ja": "顧客",
          "label_en": "Customer",
          "type": "reference",
          "ref": { "entity": "customer", "display": "name", "value": "id" },
          "ui": { "section": "header", "control": "select", "order": 30, "searchable": true },
          "required": true,
          "example": "00705: JA愛知西 ..."
        },
        {
          "key": "proposal_id",
          "label_ja": "ID",
          "label_en": "ID",
          "type": "string",
          "ui": { "section": "header", "control": "text", "order": 40, "read_only": true },
          "required": false,
          "notes": "Likely system-generated."
        },
        {
          "key": "proposal_no",
          "label_ja": "提案No",
          "label_en": "Proposal No",
          "type": "string",
          "ui": { "section": "header", "control": "text", "order": 50, "read_only": true },
          "required": false
        },
        {
          "key": "action_view",
          "label_ja": "表示",
          "label_en": "Display",
          "type": "action",
          "ui": { "section": "header", "control": "button", "order": 60 },
          "required": false,
          "action": { "type": "load_record", "inputs": ["proposal_id", "proposal_no"] }
        },
        {
          "key": "action_delete",
          "label_ja": "削除",
          "label_en": "Delete",
          "type": "action",
          "ui": { "section": "header", "control": "checkbox_or_button", "order": 70 },
          "required": false,
          "notes": "Screenshot looks like a checkbox next to label 削除. Confirm desired UX."
        },
        {
          "key": "created_at",
          "label_ja": "作成日",
          "label_en": "Created Date",
          "type": "date",
          "ui": { "section": "header", "control": "date", "order": 80, "read_only": true },
          "required": false
        },
        {
          "key": "updated_at",
          "label_ja": "最終更新日",
          "label_en": "Last Updated",
          "type": "date",
          "ui": { "section": "header", "control": "date", "order": 90, "read_only": true },
          "required": false
        },
        {
          "key": "proposal_date",
          "label_ja": "提案日",
          "label_en": "Proposal Date",
          "type": "date",
          "ui": { "section": "header", "control": "date", "order": 100 },
          "required": false,
          "example": "26/03/10",
          "notes": "Date format in legacy UI appears YY/MM/DD."
        },
        {
          "key": "decision_date",
          "label_ja": "決定日",
          "label_en": "Decision Date",
          "type": "date",
          "ui": { "section": "header", "control": "date", "order": 110 },
          "required": false,
          "example": "26/03/30"
        },
        {
          "key": "delivery_date",
          "label_ja": "納入日",
          "label_en": "Delivery Date",
          "type": "date",
          "ui": { "section": "header", "control": "date", "order": 120 },
          "required": false,
          "example": "26/04/20"
        },
        {
          "key": "list_up_posted",
          "label_ja": "リストアップ計上",
          "label_en": "List-up Posted",
          "type": "boolean",
          "ui": { "section": "header", "control": "checkbox", "order": 130 },
          "required": false,
          "default": false
        },
        {
          "key": "r_approval_status",
          "label_ja": "R承認",
          "label_en": "R Approval",
          "type": "string",
          "ui": { "section": "approval_budget", "control": "status_or_select", "order": 10 },
          "required": false,
          "notes": "Exact meaning and allowed values are TBD."
        },
        {
          "key": "r_requires_approval",
          "label_ja": "要承認",
          "label_en": "Requires Approval",
          "type": "boolean",
          "ui": { "section": "approval_budget", "control": "badge_or_checkbox", "order": 20 },
          "required": false,
          "notes": "Shown adjacent to R承認."
        },
        {
          "key": "p_approval_status",
          "label_ja": "P承認",
          "label_en": "P Approval",
          "type": "string",
          "ui": { "section": "approval_budget", "control": "status_or_select", "order": 30 },
          "required": false,
          "notes": "Exact meaning and allowed values are TBD."
        },
        {
          "key": "p_requires_approval",
          "label_ja": "要承認",
          "label_en": "Requires Approval",
          "type": "boolean",
          "ui": { "section": "approval_budget", "control": "badge_or_checkbox", "order": 40 },
          "required": false,
          "notes": "Shown adjacent to P承認."
        },
        {
          "key": "budget_total",
          "label_ja": "予算合計",
          "label_en": "Budget Total",
